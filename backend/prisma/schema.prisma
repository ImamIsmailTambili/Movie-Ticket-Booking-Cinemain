generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cinema {
  id           Int            @id @default(autoincrement())
  nama         String
  daerahId     Int
  Daerah       Daerah         @relation(fields: [daerahId], references: [id])
  FilmDiCinema FilmDiCinema[]
}

model Daerah {
  id     Int      @id @default(autoincrement())
  nama   String
  Cinema Cinema[]
}

model Film {
  id           Int            @id @default(autoincrement())
  judul        String
  genre        String
  duration     Int?
  sinopsis     String
  produser     String
  sutradara    String
  production   String
  pemeran      String
  poster       String
  trailer      String
  penulis      String
  FilmDiCinema FilmDiCinema[]
}

model FilmDiCinema {
  id            Int             @id @default(autoincrement())
  filmId        Int
  cinemaId      Int
  harga         Int
  Cinema        Cinema          @relation(fields: [cinemaId], references: [id])
  Film          Film            @relation(fields: [filmId], references: [id])
  TanggalTayang TanggalTayang[]

  @@unique([filmId, cinemaId])
}

model JamTayang {
  id              Int           @id @default(autoincrement())
  jam             String
  tanggalTayangId Int
  TanggalTayang   TanggalTayang @relation(fields: [tanggalTayangId], references: [id])
  Pesan           Pesan[]
}

model KursiTerpesan {
  id            Int @id @default(autoincrement())
  pesanId       Int
  masterKursiId Int

  MasterKursi MasterKursi @relation(fields: [masterKursiId], references: [id])
  Pesan       Pesan       @relation(fields: [pesanId], references: [id])

  @@unique([masterKursiId])
}

model MasterKursi {
  id            Int             @id @default(autoincrement())
  nomorKursi    String          @unique
  KursiTerpesan KursiTerpesan[]
}

model Pesan {
  id          Int      @id @default(autoincrement())
  userId      Int
  jamTayangId Int
  jumlahTiket Int
  status      Status   @default(PENDING)
  expiredAt   DateTime
  createdAt   DateTime @default(now())

  JamTayang     JamTayang       @relation(fields: [jamTayangId], references: [id])
  User          User            @relation(fields: [userId], references: [id])
  KursiTerpesan KursiTerpesan[]
}

enum Status {
  PENDING
  SUCCESS
  CANCELLED
}

model TanggalTayang {
  id             Int          @id @default(autoincrement())
  tanggal        DateTime     @db.Date
  filmDiCinemaId Int
  JamTayang      JamTayang[]
  FilmDiCinema   FilmDiCinema @relation(fields: [filmDiCinemaId], references: [id])
}

model User {
  id           Int       @id @default(autoincrement())
  nama         String
  telepon      String    @unique
  email        String    @unique
  gender       String
  tanggalLahir DateTime? @db.Date
  pin          String
  createdAt    DateTime  @default(now())
  Pesan        Pesan[]
}

// db admin
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String
  entity    String
  entityId  Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
